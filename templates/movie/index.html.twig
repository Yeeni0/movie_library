{% extends 'base.html.twig' %}

{% block title %}Liste des films{% endblock %}

{% block body %}
    <h1 class="mb-4">Liste des films</h1>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Titre</th>
                <th>Realisateur</th>
                <th>Annee</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for movie in movies %}
            <tr>
                <td>{{ movie.title }}</td>
                <td>{{ movie.director }}</td>
                <td>{{ movie.releaseYear }}</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" href="{{ path('app_movie_show', {'id': movie.id}) }}">Voir</a>
                    <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_movie_edit', {'id': movie.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center text-muted">Aucun film enregistre</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a class="btn btn-primary" href="{{ path('app_movie_new') }}">Ajouter un film</a>
{% endblock %}