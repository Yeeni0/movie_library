{% extends 'base.html.twig' %}

{% block title %}Liste des films{% endblock %}

{% block body %}
    <h1 class="mb-4">Liste des films</h1>

    <form method="get" action="{{ path('app_movie_index') }}" class="mb-4 row gx-2 gy-2 align-items-center">
        <div class="col-auto">
            <input
                type="search"
                name="q"
                class="form-control"
                placeholder="Rechercher un film..."
                value="{{ search|e }}"
            />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Rechercher</button>
        </div>
        {% if search is not empty %}
            <div class="col-auto">
                <a href="{{ path('app_movie_index') }}" class="btn btn-outline-secondary">Effacer</a>
            </div>
        {% endif %}
    </form>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Titre</th>
                <th>Realisateur</th>
                <th>Annee</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for movie in movies %}
            <tr>
                <td>{{ movie.title }}</td>
                <td>{{ movie.director }}</td>
                <td>{{ movie.releaseYear }}</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" href="{{ path('app_movie_show', {'id': movie.id}) }}">Voir</a>
                    <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_movie_edit', {'id': movie.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center text-muted">Aucun film enregistre</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a class="btn btn-primary" href="{{ path('app_movie_new') }}">Ajouter un film</a>
{% endblock %}